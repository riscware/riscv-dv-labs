// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
    "name": "RISCV DV Labs",
    "build": {
	"dockerfile": "Dockerfile"
    },

    // Features to add to the dev container. More info: https://containers.dev/features.
    // "features": {"golang" : "latest"},

    // Use 'forwardPorts' to make a list of ports inside the container available locally.
    // "forwardPorts": [],

    "initializeCommand": "docker login ghcr.io -u riscv-dv-workshop -p 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",
    
    // Use 'postCreateCommand' to run commands after the container is created.
    // Update PATH env variable
    "postCreateCommand": "echo 'export PATH=/opt/riscv/riscv-gnu-toolchain/2026.01.22/bin:/opt/riscv/riscv-isa-sim/2026.02.13/bin:/opt/riscv/sail-riscv/v0.9/bin:/opt/riscv/el2hex/2025.05.30/bin:/opt/riscv/uv/0.9.26/bin:/opt/riscv/qemu/v10.2.0/bin:/opt/riscv/openocd/25.10.9/bin:/opt/riscv/riscv-pk/2025.09.18/riscv64-unknown-elf/bin:/opt/verilator/verilator/v5.044-euvm-dev/bin:/opt/euvm/euvm-1.0-beta61-linux-x86_64/bin:/opt/bluespec/bsc-2025.07-ubuntu-22.04/bin:${PATH:+:$PATH}' >> ~/.bashrc && echo 'export PKG_CONFIG_PATH=/opt/riscware/riscv-isa-sim/lib/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}' >> ~/.bashrc && echo 'export BLUESPEC_HOME=/opt/riscware/bsc-2025.07-ubuntu-22.04' >> ~/.bashrc && echo 'export CPLUS_INCLUDE_PATH=/opt/riscware/riscv-isa-sim/include${CPLUS_INCLUDE_PATH:+:$CPLUS_INCLUDE_PATH}' >> ~/.bashrc && echo 'export C_INCLUDE_PATH=/opt/riscware/riscv-isa-sim/include${C_INCLUDE_PATH:+:$C_INCLUDE_PATH}' >> ~/.bashrc && bash -c \"source ~/.bashrc\"",

    // Configure tool-specific properties.
    "customizations": {
	// Configure properties specific to VS Code.
	"vscode": {
	    // Set *default* container specific settings.json values on container create.
	    // https://stackoverflow.com/questions/74645112/github-codespace-environment-setting
	    "settings": {
		// "workbench.colorTheme": "Monokai",
		"debug.allowBreakpointsEverywhere": true,
		//"cmake.useCMakePresets": "auto",
		"makefile.configureOnOpen": true
	    },	 
	    "extensions": [
		"webfreak.code-d",
		"mshr-h.VerilogHDL",
		"zhwu95.riscv",
		"surfer-project.surfer",
		"mcu-debug.memory-view",
		"fredericbonnet.cmake-test-adapter",
		"cheshirekow.cmake-format",
		"ms-vscode.cpptools",
		"ms-vscode.cpptools-extension-pack",
		"ms-vscode.makefile-tools",
		"marus25.cortex-debug",
		"tomoki1207.pdf"
	    ],
		"settings": {
        // You can also pre-configure paths inside the container
        "cortex-debug.armToolchainPath": "/opt/riscv/riscv-gnu-toolchain/2026.01.22/bin",
		"cortex-debug.gdbPath": "/opt/riscv/riscv-gnu-toolchain/2026.01.22/bin/riscv64-unknown-elf-gdb",
        "cortex-debug.openocdPath": "/opt/riscv/openocd/25.10.9/bin/openocd"
      }
	}
    }

    // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
    // "remoteUser": "root"
}
